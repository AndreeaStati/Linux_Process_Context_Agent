[Unit]
Description=EDR Mock Event Receiver
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/proc-agent
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /home/ubuntu/proc-agent/tools/event_receiver_server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target